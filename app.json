{
    "expo": {
        "name": "DeepLearningforGeneral",
        "slug": "DeepLearningforGeneral",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "userInterfaceStyle": "light",
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.hiroshisato.DeepLearningforGeneral"
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/adaptive-icon.png",
                "backgroundColor": "#ffffff"
            },
            "predictiveBackGestureEnabled": false,
            "package": "com.hiroshisato.DeepLearningforGeneral"
        },
        "web": {
            "favicon": "./assets/favicon.png"
        },
        "plugins": [
            [
                "expo-splash-screen",
                {
                    "image": "./assets/splash-icon.png",
                    "backgroundColor": "#ffffff",
                    "imageWidth": 200,
                    "resizeMode": "contain"
                }
            ]
        ]
    }
}
